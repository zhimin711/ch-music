<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:paddingBottom="@dimen/mini_player_height">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <!-- 起始目录 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/folder_scan_start_directory"
                    android:textAppearance="@style/TextViewOverline"
                    android:textColor="?android:attr/textColorSecondary" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/startDirectoryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="@style/TextViewBody1"
                    android:textColor="?android:attr/textColorPrimary"
                    tools:text="/storage/emulated/0/Music" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/lastDirectoryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textAppearance="@style/TextViewCaption"
                    android:textColor="?android:attr/textColorSecondary"
                    tools:text="上次打开：/storage/emulated/0/Download" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 存储根 -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="6dp"
            android:text="@string/folder_scan_storage_roots"
            android:textAppearance="@style/TextViewOverline"
            android:textColor="?android:attr/textColorSecondary" />

        <LinearLayout
            android:id="@+id/storageRootsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- 黑名单 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/folder_scan_blacklist"
                    android:textAppearance="@style/TextViewOverline"
                    android:textColor="?android:attr/textColorSecondary" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/blacklistSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="@style/TextViewBody1"
                    android:textColor="?android:attr/textColorPrimary"
                    tools:text="已屏蔽 3 个目录" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 打开完整文件夹浏览器 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/openFolderBrowserButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/folder_scan_browse"
            app:icon="@drawable/ic_folder" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
